# =============================================================
# LegacyLens — Environment Configuration
# Copy this file to .env and fill in your values.
# For Render deployment, set these in the Render dashboard instead.
# =============================================================

# Django
DJANGO_SETTINGS_MODULE=legacylens.settings.development
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-in-production

# =============================================================
# SUPERMEMORY — choose LOCAL (dev) or CLOUD (production)
# =============================================================

# --- Option A: LOCAL (default for development) ---
# Run: npx supermemory local
# Then copy the API key it prints here.
SUPERMEMORY_API_KEY=your-local-supermemory-key
SUPERMEMORY_BASE_URL=http://localhost:6767

# --- Option B: CLOUD (for Render / production) ---
# Sign up at https://supermemory.ai → Settings → API Keys
# SUPERMEMORY_API_KEY=sm_cloud_xxxxxxxxxxxx
# SUPERMEMORY_BASE_URL=https://api.supermemory.ai

# =============================================================
# LLM PROVIDER — any OpenAI-compatible endpoint
# =============================================================
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://ai-gateway.vercel.sh/v1
OPENAI_MODEL=openai/gpt-4o-mini

# Other supported providers:
# NVIDIA NIM:  OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
# OpenAI:      OPENAI_BASE_URL=https://api.openai.com/v1
# Ollama:      OPENAI_BASE_URL=http://localhost:11434/v1

# =============================================================
# ORGANIZATION
# =============================================================
LEGACYLENS_ORG_NAME=My_Organization
