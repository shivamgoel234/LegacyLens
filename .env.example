# LegacyLens — Environment Configuration
# Copy this file to .env and fill in your values

# Django
DJANGO_SETTINGS_MODULE=legacylens.settings.development
DJANGO_SECRET_KEY=change-me-in-production

# Supermemory Local (run: npx supermemory local)
SUPERMEMORY_API_KEY=your-supermemory-api-key
SUPERMEMORY_BASE_URL=http://localhost:6767

# LLM Provider — any OpenAI-compatible endpoint
# Options: Vercel AI Gateway, NVIDIA NIM, OpenAI, Ollama, etc.
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://ai-gateway.vercel.sh/v1
OPENAI_MODEL=openai/gpt-4o-mini

# Organization
LEGACYLENS_ORG_NAME=MyOrganization
